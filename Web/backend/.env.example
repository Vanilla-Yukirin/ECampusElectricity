# ========================================
# ECampusElectricity 统一配置文件
# ========================================

# 数据库配置 (PostgreSQL 17)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/electricity_db

# 或者分别配置 (推荐用于复杂部署)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=electricity_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT 认证配置
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# SMTP 邮件配置
SMTP_SERVER=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password
FROM_EMAIL=your-email@domain.com
USE_TLS=false

# 易校园 API 配置
SHIRO_JID=your-shiro-jid-here
API_BASE_URL=https://application.xiaofubao.com/app/electric

# QQ Bot 配置
QQ_APPID=your_qq_appid
QQ_SECRET=your_qq_secret

# Tracker 配置
TRACKER_CHECK_INTERVAL=3600
HISTORY_LIMIT=2400

# 图床配置
UPLOADER_TOKEN=your_uploader_token
UPLOADER_ALBUM_ID=your_album_id
